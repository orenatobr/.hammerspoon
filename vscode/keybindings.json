[
  {
    "key": "cmd+shift+alt+r",
    "command": "workbench.action.reloadWindow"
  },
  {
    "key": "cmd+shift+alt+a",
    "command": "workbench.action.focusAuxiliaryBar"
  },
  {
    "key": "cmd+shift+alt+t",
    "command": "runCommands",
